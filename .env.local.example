# Copy this file to `.env.local` and fill in your real DeepSeek API key.
# Get one at https://platform.deepseek.com after topping up your balance.
DEEPSEEK_API_KEY=sk-your-key-here

# Optional: switch model. Defaults to "deepseek-reasoner" (R1).
# Use "deepseek-chat" (V3) for faster / cheaper responses.
# DEEPSEEK_MODEL=deepseek-reasoner
