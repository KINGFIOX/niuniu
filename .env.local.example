# Copy this file to `.env.local` and fill in your real keys.

# ---------- DeepSeek (chat) ----------
# Get a key at https://platform.deepseek.com after topping up your balance.
DEEPSEEK_API_KEY=sk-your-key-here

# Optional: switch model. Defaults to "deepseek-reasoner" (R1).
# Use "deepseek-chat" (V3) for faster / cheaper responses.
# DEEPSEEK_MODEL=deepseek-reasoner

# ---------- Volcengine (voice STT + TTS) ----------
# Register at https://console.volcengine.com, open the following services
# under 豆包语音 → API 服务中心:
#   1. 豆包语音合成模型2.0 字符版           (used by /api/tts)
#   2. 豆包录音文件识别模型2.0 标准版       (used by /api/stt)
# Then copy the AppID + Access Token from "服务接口认证信息".
VOLC_APP_ID=your-volc-app-id
VOLC_ACCESS_TOKEN=your-volc-access-token

# Voice type for 豆包语音合成模型2.0. Trial 字符版 includes the official
# Seed-TTS 2.0 voices (`_uranus_bigtts` family).
# Browse all voices: 火山控制台 → 豆包语音 → 音色管理.
# Examples (Seed-TTS 2.0):
#   zh_female_vv_uranus_bigtts        (Vivi · 元气甜美少女, default)
#   zh_female_cancan_uranus_bigtts    (灿灿)
#   zh_male_m191_uranus_bigtts        (云舟)
#   zh_male_liufei_uranus_bigtts      (刘飞)
VOLC_TTS_VOICE_TYPE=zh_female_vv_uranus_bigtts

# Optional: override the X-Api-Resource-Id sent to TTS. By default we
# auto-derive it from the voice name (uranus/saturn → seed-tts-2.0,
# moon/mars → seed-tts-1.0, S_* → seed-icl-2.0). Only set this if you've
# opened a custom package (e.g. seed-tts-1.0-concurr for high concurrency).
# VOLC_TTS_RESOURCE_ID=seed-tts-2.0

# ASR resource id. Default `volc.seedasr.auc` works for 豆包录音文件识别模型
# 2.0 标准版. If the API returns 403 "resource not granted", uncomment and
# try `volc.bigasr.auc` (older naming).
# VOLC_ASR_RESOURCE_ID=volc.seedasr.auc
